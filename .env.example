# =========================================================================
# NutriBot Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# DO NOT commit your actual '.env' file to GitHub!
# =========================================================================

# 1. Telegram Bot Token (Obtained from @BotFather on Telegram)
# Format: <numbers>:<random_characters>
TELEGRAM_BOT_TOKEN=123456789:AABBCCddeeffGGhhiijjkkllmmnnooppqqr

# 2. Gemini Developer API Key (Obtained from Google AI Studio)
# Format: Standard AIzaSy... string
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere123456789abc

# 3. Turso Database Connection URL (Obtained from Turso CLI or Dashboard)
# Format: libsql://<your-db-name>-<your-username>.turso.io
TURSO_DATABASE_URL=libsql://nutribot-db-viseth28.turso.io

# 4. Turso Database Authorization Token (Obtained from Turso CLI or Dashboard)
# Format: A long JWT token string
TURSO_AUTH_TOKEN=eyJhbGciOiJFUzI1NiIsInR5cCI6IkpXVCJ9.eyJleHQiOiJ0dXJzbyIsImlhdCI6MTcwMDAwMDAwMCwibmJmIjoxNzAwMDAwMDAwLCJzdWIiOiJudXRyaWJvdC1kYiJ9.ExampleTokenThisIsAStagingOrTestTokenDoNotUseInProductionAsIs
